ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional — free Demo API key from https://www.coingecko.com/en/api (raises rate limits)
COINGECKO_API_KEY=CG-your-demo-api-key-here
# Optional — holder breakdown on EVM chains (eth, base, bsc, etc.) via Etherscan API v2
ETHERSCAN_API_KEY=your-etherscan-api-key
# Optional — holder breakdown on Solana via Solscan Pro (fallback: public Solana RPC)
SOLSCAN_API_KEY=your-solscan-api-key
# Optional — custom Solana RPC if public endpoint is rate-limited
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
